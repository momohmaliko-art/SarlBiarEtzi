@{
    ViewData["Title"] = "Reviews";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background: radial-gradient(circle at top, #0b1220, #050814);
        color: white;
        font-family: Arial;
        overflow-x: hidden;
    }

    /* ===== CENTER WRAPPER ===== */
    .page-wrapper {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 40px 15px;
        flex-direction: column;
    }

    /* ===== MAIN 3D CARD ===== */
    .auth-3d-card {
        width: 100%;
        max-width: 450px;
        margin: auto;
        padding: 25px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(96,165,250,0.25);
        border-radius: 22px;
        backdrop-filter: blur(18px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.5), inset 0 0 25px rgba(96,165,250,0.05);
        transform: perspective(1000px);
        transition: 0.4s ease;
    }

        .auth-3d-card:hover {
            transform: perspective(1000px) rotateX(6deg) rotateY(-6deg) scale(1.02);
            box-shadow: 0 25px 80px rgba(59,130,246,0.25), inset 0 0 30px rgba(96,165,250,0.1);
        }

    h2 {
        text-align: center;
        color: #60a5fa;
        margin-bottom: 5px;
    }

    .subtitle {
        text-align: center;
        font-size: 13px;
        opacity: 0.6;
        margin-bottom: 15px;
    }

    /* ===== INPUTS ===== */
    input, textarea {
        width: 100%;
        margin-top: 10px;
        padding: 10px;
        border-radius: 12px;
        border: 1px solid rgba(96,165,250,0.3);
        background: rgba(0,0,0,0.25);
        color: white;
        outline: none;
    }

    textarea {
        height: 90px;
    }

    /* ===== BUTTON ===== */
    .btn-3d {
        width: 100%;
        margin-top: 12px;
        padding: 10px;
        background: linear-gradient(135deg, #3b82f6, #1e3a8a);
        border: none;
        border-radius: 12px;
        color: white;
        font-weight: bold;
        box-shadow: 0 6px 0 #0b1a40;
        transition: 0.2s;
    }

        .btn-3d:active {
            transform: translateY(4px);
            box-shadow: 0 2px 0 #0b1a40;
        }

    /* ===== USER ===== */
    .user-email {
        text-align: center;
        color: #22c55e;
        margin-top: 10px;
        font-size: 13px;
    }

    /* ===== STARS ===== */
    .stars {
        text-align: center;
        font-size: 32px;
        cursor: pointer;
        margin: 10px 0;
        color: gold;
        letter-spacing: 3px;
    }

    /* ===== REVIEWS ===== */
    .reviews-container {
        margin-top: 40px;
        display: flex;
        gap: 15px;
        overflow-x: auto;
        padding: 10px;
        scroll-behavior: smooth;
        width: 100%;
    }

    .review-card {
        min-width: 260px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(96,165,250,0.2);
        border-radius: 16px;
        padding: 15px;
        backdrop-filter: blur(10px);
        transition: 0.4s;
        cursor: pointer;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

        .review-card:hover {
            transform: perspective(800px) rotateY(8deg) rotateX(6deg) scale(1.05);
            border: 1px solid rgba(96,165,250,0.5);
            box-shadow: 0 20px 60px rgba(59,130,246,0.25);
        }

    .email-tag {
        color: #60a5fa;
        font-size: 13px;
        margin-bottom: 5px;
    }

    .rating {
        color: gold;
        margin-bottom: 5px;
    }

    .comment {
        font-size: 14px;
        opacity: 0.9;
    }
</style>

<div class="page-wrapper">

    <!-- ===== AUTH + REVIEW CARD ===== -->
    <div class="auth-3d-card" id="loginPopup">

        <h2>Rate Our Company ⭐</h2>
        <p class="subtitle">Login first to submit your review</p>

        <input type="email" id="email" placeholder="Enter Email">

        <button class="btn-3d" onclick="sendOTP()">Send OTP</button>

        <input type="text" id="otp" placeholder="Enter OTP">

        <button class="btn-3d" onclick="verifyOTP()">Verify</button>

        <div id="userEmail" class="user-email"></div>

        <hr style="opacity:0.2">

        <div class="stars" id="stars">★★★★★</div>

        <form method="post" action="/Home/AddReview" id="reviewForm">

            <input type="hidden" name="stars" id="starsInput" value="5" />
            <input type="hidden" name="email" id="emailInput" />

            <textarea name="comment" placeholder="Write your comment..." required></textarea>

            <button class="btn-3d" type="submit">Send Review</button>
        </form>

    </div>

    <!-- ===== REVIEWS ===== -->
    <div class="reviews-container" id="reviewsContainer"></div>

</div>

<script>
    let loggedIn = false;

    function sendOTP() {
        fetch('/Home/SendOTP', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: "email=" + email.value
        });
        alert("OTP sent 📩");
    }

    function verifyOTP() {
        fetch('/Home/VerifyOTP', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: "email=" + email.value + "&otp=" + otp.value
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                loggedIn = true;

                document.getElementById("userEmail").innerText = "Logged as: " + email.value;
                document.getElementById("emailInput").value = email.value;

                alert("Welcome ✅");
            } else {
                alert("Wrong OTP ❌");
            }
        });
    }

    document.getElementById("reviewForm").addEventListener("submit", function(e){
        if(!loggedIn){
            e.preventDefault();
            alert("You must login first ❌");
        }
    });

    const stars = document.getElementById("stars");
    const starsInput = document.getElementById("starsInput");

    let current = 5;

    stars.addEventListener("click", function(){
        current = current === 5 ? 1 : current + 1;
        starsInput.value = current;
        stars.innerHTML = "★".repeat(current) + "☆".repeat(5-current);
    });

    const container = document.getElementById("reviewsContainer");

    function addCard(email, stars, comment){
        const div = document.createElement("div");
        div.className = "review-card";

        div.innerHTML = `
            <div class="email-tag">${email}</div>
            <div class="rating">${"★".repeat(stars)}</div>
            <div class="comment">${comment}</div>
        `;

        container.appendChild(div);
    }

    @foreach (var item in Model)
    {
            <text>
                    addCard("@item.Email", @item.Stars, "@Html.Raw(item.Comment.Replace("\"", "'"))");
            </text>
    }
</script>
