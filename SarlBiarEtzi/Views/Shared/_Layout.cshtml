<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SarlBiarEtzi</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body {
            margin: 0;
            background: #111111;
            color: white;
            overflow-x: hidden;
            font-family: Arial;
        }

        #particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: radial-gradient(circle, #1a1a1a, #0d0d0d);
        }

        /* ================= NAVBAR ================= */
        .navbar-glass {
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            box-shadow: 0 10px 30px rgba(0,0,0,0.6);
            transition: all 0.3s ease;
        }

        .navbar-scrolled {
            background: rgba(10, 15, 30, 0.9);
            backdrop-filter: blur(18px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.8);
            border-bottom: 1px solid rgba(96,165,250,0.25);
        }

        .navbar-brand {
            font-weight: bold;
            font-size: 22px;
            letter-spacing: 2px;
            color: cornflowerblue !important;
        }

        /* ================= NAV LINKS ================= */
        .nav-link {
            color: white !important;
            margin: 0 10px;
            position: relative;
            transition: 0.3s;
        }

        .nav-link::after {
            content: "";
            position: absolute;
            width: 0%;
            height: 2px;
            left: 0;
            bottom: -5px;
            background: #60a5fa;
            transition: 0.3s;
        }

        .nav-link:hover::after {
            width: 100%;
        }

        .nav-link:hover {
            color: #60a5fa !important;
        }

        /* ================= FOOTER ================= */
        footer {
            background: rgba(0,0,0,0.7);
            color: white;
            text-align: center;
            padding: 15px;
            margin-top: 50px;
        }

        /* ================= TRANSLATE ================= */
        .translate-box {
            background: rgba(0,0,0,0.5);
            padding: 5px 10px;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.1);
            margin-left: 10px;
        }

        .goog-te-combo {
            background: #111;
            color: white;
            border: 1px solid #333;
            padding: 4px;
            border-radius: 6px;
        }

        .goog-te-banner-frame,
        .goog-te-gadget-icon {
            display: none !important;
        }

        body { top: 0px !important; }

        /* ================= LOGO ================= */
        .logo-3d img {
            height: 100px;
            width: auto;
            border-radius: 20px;
            transition: 0.4s;
            filter: drop-shadow(0 0 10px rgba(96,165,250,0.9));
            transform-style: preserve-3d;
            animation: floatLogo 3s ease-in-out infinite;
        }

        .logo-3d:hover img {
            transform: rotateY(15deg) rotateX(10deg) scale(1.1);
        }

        @@keyframes floatLogo {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-3px); }
            100% { transform: translateY(0px); }
        }

        /* ================= PAGE ANIMATION ================= */
        .page-transition {
            animation: fadeInPage 0.7s ease;
        }

        @@keyframes fadeInPage {
            from {
                opacity: 0;
                transform: translateY(15px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ================= SCROLL REVEAL ================= */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: 0.8s ease;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        .parallax {
    transform: translateY(0);
    transition: transform 0.2s ease-out;
}

        #loader {
    position: fixed;
    width: 100%;
    height: 100%;
    background: #0b0f1a;
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    z-index: 99999;
}

.spinner {
    width: 60px;
    height: 60px;
    border: 4px solid rgba(255,255,255,0.1);
    border-top: 4px solid #60a5fa;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.loader-text {
    margin-top: 15px;
    color: #60a5fa;
    font-size: 14px;
    letter-spacing: 2px;
}




html {
    scroll-behavior: smooth;
}



    </style>

</head>

<body>
    <div id="loader">
    <div class="spinner"></div>
    <div class="loader-text">Loading BIAR ETZI...</div>
</div>

    <canvas id="particles"></canvas>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-glass">
        <div class="container-fluid">

            <a class="navbar-brand logo-3d d-flex align-items-center"
               asp-controller="Home" asp-action="Index">
                <img src="~/photo/unnamed.jpg" alt="Logo">
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="nav">
                <ul class="navbar-nav align-items-center">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Contact" asp-action="Contact">Contact</a>
                    </li>

                    <li class="nav-item">
                       <a class="nav-link" asp-controller="Home" asp-action="Privacy" id="privacyLink">Privacy</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Reviews">Reviews</a>
                    </li>

                    <li class="nav-item translate-box">
                        <div id="google_translate_element"></div>
                    </li>

                </ul>
            </div>

        </div>
    </nav>

    <!-- CONTENT -->
    <div class="container page-transition">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer>
        © 2026 - SarlBiarEtzi | Construction Company
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- GOOGLE TRANSLATE -->
    <script>
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({
                pageLanguage: 'en',
                includedLanguages: 'en,fr,ar',
                layout: google.translate.TranslateElement.InlineLayout.SIMPLE
            }, 'google_translate_element');
        }
    </script>

    <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    <!-- SIGNALR NOTIFICATIONS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.on("ReceiveNotification", function (msg) {

            let box = document.createElement("div");
            box.innerHTML = msg;
            box.style.position = "fixed";
            box.style.bottom = "20px";
            box.style.right = "20px";
            box.style.background = "rgba(0,0,0,0.85)";
            box.style.color = "#fff";
            box.style.padding = "12px 20px";
            box.style.borderRadius = "10px";
            box.style.border = "1px solid #60a5fa";
            box.style.boxShadow = "0 10px 30px rgba(0,0,0,0.5)";
            box.style.zIndex = "9999";

            document.body.appendChild(box);

            setTimeout(() => {
                box.remove();
            }, 4000);
        });

       connection.start()
    .then(() => console.log("SignalR connected"))
    .catch(err => console.error("SignalR error:", err));

        /* ================= NAVBAR SCROLL ================= */
        const navbar = document.querySelector(".navbar-glass");

        window.addEventListener("scroll", () => {
            if (window.scrollY > 40) {
                navbar.classList.add("navbar-scrolled");
            } else {
                navbar.classList.remove("navbar-scrolled");
            }
        });

        /* ================= SCROLL REVEAL ================= */
        function reveal() {
            document.querySelectorAll(".reveal").forEach(el => {
                const top = el.getBoundingClientRect().top;
                if (top < window.innerHeight - 100) {
                    el.classList.add("active");
                }
            });
        }

        window.addEventListener("scroll", reveal);
        reveal();
    </script>



   <script>
    const loader = document.getElementById("loader");
    const privacyLink = document.getElementById("privacyLink");

    privacyLink.addEventListener("click", function (e) {
        e.preventDefault(); // نوقف التنقل مباشرة

        loader.style.display = "flex";

        setTimeout(() => {
            window.location.href = privacyLink.href;
        }, 1200); // وقت loader
    });
</script>


<script>
    window.addEventListener("scroll", () => {
        let y = window.scrollY * 0.3;

        document.querySelectorAll(".parallax").forEach(el => {
            el.style.transform = `translateY(${y}px)`;
        });
    });
</script>



<script>

// JavaScript
navigator.permissions.query({ name: 'geolocation' }).then(result => { /* ... */ });
</script>


</body>
</html>
